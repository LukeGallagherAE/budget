{
  "name": "budget-tracker-backend",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:client\"",
    "dev:client": "npm --prefix client run dev",
    "build:client": "npm --prefix client run build",
    "install:all": "npm install && npm --prefix client install"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
