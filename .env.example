# PostgreSQL connection string
# Local dev: postgresql://user:password@localhost:5432/expenseradar
# Railway: set automatically when you add a Postgres service
DATABASE_URL=postgresql://user:password@localhost:5432/expenseradar

# Secret used to sign JWT tokens — generate with: openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_string

# Set to "production" on Railway (set automatically)
NODE_ENV=development
